FROM node:20-alpine

# Instalar Nginx (versao disponivel)
RUN apk add --no-cache nginx

WORKDIR /app

# Copiar dependencias e instalar
COPY package*.json ./
RUN npm install

# Copiar codigo-fonte
COPY . .

# Criar diretorio SSL e copiar certificados
RUN mkdir -p /etc/nginx/ssl
COPY ssl/localhost.crt /etc/nginx/ssl/localhost.crt
COPY ssl/localhost.key /etc/nginx/ssl/localhost.key

# Copiar configuracao Nginx para dev
COPY nginx.dev.conf /etc/nginx/conf.d/default.conf

# Script de inicializacao simplificado
RUN printf '#!/bin/sh\nset -e\necho "Starting Nginx.."\nnginx -g "daemon off;" &\necho "Starting Vite dev server..."\nnpx vite --host 0.0.0.0 --port 5173\n' > /app/start.sh && chmod +x /app/start.sh

EXPOSE 8080 5173

CMD ["/bin/sh", "/app/start.sh"]
